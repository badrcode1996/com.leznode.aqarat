rules_version = '2';

// =============================================================================
// Aqarat — multi-tenant security rules.
//
// Tenant boundary: a document is only readable/writable by users whose
// `users/{uid}.company_id` matches the document's `company_id`.
//
// Super Admins (SaaS owners) are identified by their profile document
// (users/{uid}.role == 'super_admin') — NOT by a hardcoded email. This supports
// any number of super admins, managed as Firestore documents. They may
// provision companies and users across all tenants.
// =============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function profileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && profileExists()
        && userData().role == 'super_admin';
    }

    // True if the signed-in user has a profile and belongs to company [cid].
    function sameCompany(cid) {
      return isSignedIn() && profileExists() && userData().company_id == cid;
    }

    // True if the user sees EVERY branch of their company: a company-wide admin
    // (a company_admin who is NOT branch-scoped). Super admins are handled
    // separately at each rule. Only called once sameCompany() proved the profile
    // exists, so userData() is safe here.
    // Safe field access (.get with default): a user doc created before the
    // branch system may LACK `branch` / `branch_admin`, and reading a missing
    // field in rules ERRORS → denies the whole request. Defaults keep such
    // accounts working (treated as company-wide-eligible / empty branch).
    function seesAllBranches() {
      return userData().role == 'company_admin'
        && userData().get('branch_admin', false) != true;
    }

    // Branch boundary: a member may touch a doc in company [cid] / branch
    // [branch] only if they belong to that company AND either see all branches
    // or sit in the same branch. Agents and branch-scoped admins are thus
    // confined to their own branch's data.
    function inBranch(cid, branch) {
      return sameCompany(cid)
        && (seesAllBranches() || userData().get('branch', '') == branch);
    }

    // --- Global app config (e.g. the Super-Admin-edited plan matrix). Any
    //     signed-in user may read it (the app gates features off it); only
    //     Super Admins may edit. Plan feature gating is enforced in the app +
    //     the admin provisioning flow, not here.
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // --- User profiles.
    //     ONLY the Super Admin provisions profiles (the app has no self-signup).
    //     A self-created profile is forbidden: otherwise anyone who registers an
    //     auth account could mint themselves a company_admin profile on any
    //     company and breach that tenant. A user may update only their own
    //     editable fields and never their company_id / role.
    match /users/{uid} {
      allow read: if isSuperAdmin() || (isSignedIn() &&
        (request.auth.uid == uid || sameCompany(resource.data.company_id)));
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.company_id == resource.data.company_id
        && request.resource.data.role == resource.data.role);
      allow delete: if isSuperAdmin();
    }

    // --- Companies. Members READ their own company; only the Super Admin may
    //     create/edit/delete it (plan, city, web_only, feature_overrides,
    //     branches are all sold/provisioned — a member must not self-upgrade).
    match /companies/{companyId} {
      allow read: if isSuperAdmin() || sameCompany(companyId);
      allow create, update, delete: if isSuperAdmin();
    }

    // --- Aggregated stats: one doc per company (doc id == company_id).
    match /company_stats/{companyId} {
      allow read, write: if isSuperAdmin() || sameCompany(companyId);
    }

    // --- Contracts: company- AND branch-scoped. A member only ever touches
    //     their own branch's docs (company-wide admins + super admins see all).
    //     company_id and branch are pinned on update so a doc can never be
    //     re-tagged into another tenant or branch.
    match /contracts/{id} {
      allow read:   if isSuperAdmin()
        || inBranch(resource.data.company_id, resource.data.branch);
      allow create: if inBranch(request.resource.data.company_id,
        request.resource.data.branch);
      allow update: if (isSuperAdmin()
          || inBranch(resource.data.company_id, resource.data.branch))
        && request.resource.data.company_id == resource.data.company_id
        && request.resource.data.branch == resource.data.branch;
      allow delete: if isSuperAdmin()
        || inBranch(resource.data.company_id, resource.data.branch);
    }

    // --- Receipts (وەصڵ): company- AND branch-scoped, same as contracts.
    match /receipts/{id} {
      allow read:   if isSuperAdmin()
        || inBranch(resource.data.company_id, resource.data.branch);
      allow create: if inBranch(request.resource.data.company_id,
        request.resource.data.branch);
      allow update: if (isSuperAdmin()
          || inBranch(resource.data.company_id, resource.data.branch))
        && request.resource.data.company_id == resource.data.company_id
        && request.resource.data.branch == resource.data.branch;
      allow delete: if isSuperAdmin()
        || inBranch(resource.data.company_id, resource.data.branch);
    }

    // --- Contract templates (تێمپلەیت): one doc per company (id == company_id).
    //     The owning company reads it to render PDFs; only super admins edit.
    match /templates/{companyId} {
      allow read:  if isSuperAdmin() || sameCompany(companyId);
      allow write: if isSuperAdmin();
    }

    // --- Lawyers (پارێزەران): company-scoped directory managed by the company
    //     admin (admin restriction enforced client-side). Agents read them to
    //     pick a lawyer on the sale contract form.
    match /lawyers/{id} {
      allow read:   if isSuperAdmin() || sameCompany(resource.data.company_id);
      allow create: if sameCompany(request.resource.data.company_id);
      allow update: if sameCompany(resource.data.company_id)
        && request.resource.data.company_id == resource.data.company_id;
      allow delete: if sameCompany(resource.data.company_id);
    }

    // --- Listings: STRICTLY company-scoped. These docs hold private owner
    //     name/phone, so they are NEVER readable cross-company. The Global
    //     Market reads the separate owner-free `market` collection instead.
    match /properties/{id} {
      allow read:   if isSuperAdmin()
        || inBranch(resource.data.company_id, resource.data.branch);
      allow create: if inBranch(request.resource.data.company_id,
        request.resource.data.branch);
      allow update: if (isSuperAdmin()
          || inBranch(resource.data.company_id, resource.data.branch))
        && request.resource.data.company_id == resource.data.company_id
        && request.resource.data.branch == resource.data.branch;
      allow delete: if isSuperAdmin()
        || inBranch(resource.data.company_id, resource.data.branch);
    }

    match /requests/{id} {
      allow read:   if isSuperAdmin()
        || inBranch(resource.data.company_id, resource.data.branch);
      allow create: if inBranch(request.resource.data.company_id,
        request.resource.data.branch);
      allow update: if (isSuperAdmin()
          || inBranch(resource.data.company_id, resource.data.branch))
        && request.resource.data.company_id == resource.data.company_id
        && request.resource.data.branch == resource.data.branch;
      allow delete: if isSuperAdmin()
        || inBranch(resource.data.company_id, resource.data.branch);
    }

    // --- Market: the public, owner-free projection of public listings. Any
    //     signed-in user may READ it (cross-company browsing) — it carries no
    //     owner name/phone. A company writes only its own market docs, and the
    //     owner-free guarantee is enforced here (not just client-side): a market
    //     doc may never carry the private owner_name / owner_mobile fields.
    function marketOwnerFree() {
      return !('owner_name' in request.resource.data)
        && !('owner_mobile' in request.resource.data);
    }
    match /market/{id} {
      allow read:   if isSignedIn();
      allow create: if sameCompany(request.resource.data.company_id)
        && marketOwnerFree();
      allow update: if sameCompany(resource.data.company_id)
        && request.resource.data.company_id == resource.data.company_id
        && marketOwnerFree();
      allow delete: if sameCompany(resource.data.company_id);
    }
  }
}
