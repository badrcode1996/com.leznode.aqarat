rules_version = '2';

// Reads are open to signed-in users (logos are public branding); WRITES are
// restricted to the owning company (logos to the Super Admin) so a company can
// never overwrite another's images. Everything else is denied.
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }
    function callerData() {
      return firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    function isImageUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Company logos — public branding, written by the Super Admin only.
    match /company_logos/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
        && callerData().role == 'super_admin'
        && isImageUnder5MB();
    }
    // Lawyer photos — only the owning company may write.
    match /lawyer_photos/{companyId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && callerData().company_id == companyId
        && isImageUnder5MB();
    }
    // House photos (contracts/listings) — only the owning company may write;
    // read by signed-in users (market images are shown cross-company).
    match /property_images/{companyId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && callerData().company_id == companyId
        && isImageUnder5MB();
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
