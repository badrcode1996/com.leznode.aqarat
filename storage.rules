rules_version = '2';

// Company logos are non-sensitive branding shown in the app and on printed
// contracts, so they are publicly readable. Writes require a signed-in user
// (provisioning is performed by the Super Admin). Everything else is denied.
service firebase.storage {
  match /b/{bucket}/o {
    match /company_logos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Lawyer photos: shown in-app and on the sale-contract picker. Readable by
    // signed-in users; writes require a signed-in user (admin-gated in the UI).
    match /lawyer_photos/{companyId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // House photos for contracts/listings/requests. Readable by signed-in
    // users; writes require a signed-in user (tenant-gated in the UI).
    match /property_images/{companyId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
